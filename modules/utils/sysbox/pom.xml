<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <parent>
        <artifactId>parent</artifactId>
        <groupId>terefang.makeroot</groupId>
        <version>2021.1.0</version>
        <relativePath>../../../pom.xml</relativePath>
    </parent>
    <modelVersion>4.0.0</modelVersion>

    <groupId>terefang.makeroot.baseos</groupId>
    <artifactId>sysbox</artifactId>
    <version>${version.sysbox}</version>
    <packaging>pom</packaging>

    <properties>
        <prg.tag>${project.artifactId}-${project.version}</prg.tag>
    </properties>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-antrun-plugin</artifactId>
                <version>1.8</version>
                <inherited>false</inherited>
                <dependencies>
                    <dependency>
                        <groupId>org.redline-rpm</groupId>
                        <artifactId>redline</artifactId>
                        <version>1.2.9</version>
                        <classifier>jar-with-dependencies</classifier>
                    </dependency>
                    <dependency>
                        <groupId>org.apache.ant</groupId>
                        <artifactId>ant-compress</artifactId>
                        <version>1.5</version>
                    </dependency>
                    <dependency>
                        <groupId>com.github.terefang</groupId>
                        <artifactId>ant-archive-plus</artifactId>
                        <version>1.5.2</version>
                    </dependency>
                </dependencies>
                <executions>
                    <execution>
                        <id>ant</id>
                        <phase>package</phase>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <configuration>
                            <target xmlns:if="ant:if" xmlns:unless="ant:unless">
                                <taskdef classname="org.redline_rpm.ant.RedlineTask" name="xrpm" />
                                <taskdef classname="org.apache.ant.compress.taskdefs.Cpio" name="cpio" />

                                <taskdef name="xtar" classname="com.github.terefang.ant.archiveplus.taskdefs.Tar" />
                                <typedef name="symlink" classname="com.github.terefang.ant.archiveplus.resources.SymbolicLink" />

                                <mkdir dir="${rpm.path}"/>
                                <mkdir dir="${project.build.directory}/${project.artifactId}"/>
                                <mkdir dir="${toolchain.dir}"/>
                                <mkdir dir="${project.basedir}/src/main/dist"/>
                                <get unless:true="${binary.exists}" src="https://github.com/skx/sysbox/releases/download/release-${project.version}/sysbox-linux-amd64" dest="${project.basedir}/src/main/dist/${prg.tag}" />

                                <copy tofile="${project.build.directory}/${project.artifactId}/${project.artifactId}">
                                    <fileset file="${project.basedir}/src/main/dist/${prg.tag}" />
                                </copy>

                                <xrpm
                                        architecture="X86_64"
                                        destination="${project.build.directory}"
                                        license="ASL"
                                        group="${project.artifactId}"
                                        name="${project.artifactId}"
                                        summary="${project.artifactId}"
                                        distribution="${project.artifactId}"
                                        packager="${project.artifactId}"
                                        url=""
                                        vendor="${project.artifactId}"
                                        epoch="${buildNumber}"
                                        release="${buildNumber}.${timestamp}"
                                        version="${project.version}">

                                    <rpmfileset prefix="/data/toolbox/${project.artifactId}" filemode='555' file="${project.build.directory}/${project.artifactId}/${project.artifactId}" username="root" group="root" addParents="false" />

                                    <link path="/data/toolbox/${project.artifactId}/calc" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/choose-file" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/choose-stdin" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/chronic" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/collapse" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/comments" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/cpp" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/env-template" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/exec-stdin" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/expect" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/fingerd" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/html2text" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/http-get" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/httpd" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/ips" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/make-password" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/markdown-toc" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/run-directory" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/splay" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/ssl-expiry" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/timeout" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/todo" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/tree" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/urls" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/validate-json" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/validate-xml" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/validate-yaml" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/watch" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />
                                    <link path="/data/toolbox/${project.artifactId}/with-lock" target="/data/toolbox/${project.artifactId}/${project.artifactId}" />

                                </xrpm>

                                <xrpm
                                        architecture="X86_64"
                                        destination="${project.build.directory}"
                                        license="ASL"
                                        group="${project.artifactId}"
                                        name="toolbox-${project.artifactId}"
                                        summary="${project.artifactId}"
                                        distribution="${project.artifactId}"
                                        packager="${project.artifactId}"
                                        url=""
                                        vendor="${project.artifactId}"
                                        epoch="${buildNumber}"
                                        release="${buildNumber}~${timestamp}"
                                        version="${project.version}">

                                    <rpmfileset prefix="/data/toolbox/xbin" filemode='555' file="${project.build.directory}/${project.artifactId}/${project.artifactId}" username="root" group="root" addParents="false" />

                                    <link path="/data/toolbox/xbin/calc"             target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/choose-file"      target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/choose-stdin"     target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/chronic"          target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/collapse"         target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/comments"         target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/cpp"              target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/env-template"     target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/exec-stdin"       target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/expect"           target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/fingerd"          target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/html2text"        target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/http-get"         target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/ips"              target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/make-password"    target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/markdown-toc"     target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/run-directory"    target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/splay"            target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/ssl-expiry"       target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/timeout"          target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/todo"             target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/tree"             target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/urls"             target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/validate-json"    target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/validate-xml"     target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/validate-yaml"    target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/watch"            target="/data/toolbox/xbin/${project.artifactId}" />
                                    <link path="/data/toolbox/xbin/with-lock"        target="/data/toolbox/xbin/${project.artifactId}" />

                                </xrpm>
                                <copy file="${project.build.directory}/toolbox-${project.artifactId}-${project.version}-${buildNumber}~${timestamp}.x86_64.rpm" todir="${toolbox.dir}/"/>

                            </target>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

</project>