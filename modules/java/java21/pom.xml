<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <parent>
        <artifactId>parent</artifactId>
        <groupId>terefang.makeroot</groupId>
        <version>2021.1.0</version>
        <relativePath>../../../pom.xml</relativePath>
    </parent>
    <modelVersion>4.0.0</modelVersion>

    <groupId>terefang.makeroot.baseos</groupId>
    <artifactId>java21</artifactId>
    <version>21.0.10.zulu21.48.17.fx</version>
    <packaging>pom</packaging>

    <properties>
        <prg.tag>${project.artifactId}-${project.version}</prg.tag>
        <prg.url>https://cdn.azul.com/zulu/bin/zulu21.48.17-ca-fx-jdk21.0.10-linux_x64.tar.gz</prg.url>
        <prg.archive>${prg.tag}.tar.gz</prg.archive>
    </properties>

    <!--
    curl -L https://cdn.azul.com/zulu/bin/ |xq -q a -a href |grep -P fx-jdk.*linux_x64.tar|sort
    -->
    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-antrun-plugin</artifactId>
                <version>1.8</version>
                <inherited>false</inherited>
                <dependencies>
                    <dependency>
                        <groupId>org.redline-rpm</groupId>
                        <artifactId>redline</artifactId>
                        <version>1.2.9</version>
                        <classifier>jar-with-dependencies</classifier>
                    </dependency>
                    <dependency>
                        <groupId>org.apache.ant</groupId>
                        <artifactId>ant-compress</artifactId>
                        <version>1.5</version>
                    </dependency>
                </dependencies>
                <executions>
                    <execution>
                        <id>ant</id>
                        <phase>package</phase>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <configuration>
                            <target xmlns:if="ant:if" xmlns:unless="ant:unless">
                                <taskdef classname="org.redline_rpm.ant.RedlineTask" name="xrpm" />
                                <taskdef classname="org.apache.ant.compress.taskdefs.Cpio" name="cpio" />

                                <mkdir dir="${project.build.directory}/${project.artifactId}"/>
                                <get src="${prg.url}" dest="${project.basedir}/src/main/dist/${prg.archive}" />
                                <exec dir="${project.build.directory}/${project.artifactId}" executable="tar">
                                    <arg line="--strip-components=1 -xvf ${project.basedir}/src/main/dist/${prg.archive}" />
                                </exec>
                                <xrpm
                                        architecture="X86_64"
                                        destination="${project.build.directory}"
                                        license="GNU"
                                        group="${project.artifactId}"
                                        name="toolbox-${project.artifactId}"
                                        summary="${project.artifactId}"
                                        distribution="${project.artifactId}"
                                        packager="${project.artifactId}"
                                        url=""
                                        vendor="${project.artifactId}"
                                        epoch="${buildNumber}"
                                        release="${buildNumber}~${timestamp}"
                                        version="${project.version}">

                                    <rpmfileset prefix="/data/toolbox/java21/bin" filemode='555' dirmode="755" dir="${project.build.directory}/${project.artifactId}/bin" username="root" group="root" addParents="false" />
                                    <rpmfileset prefix="/data/toolbox/java21/lib" filemode='555' dirmode="755" dir="${project.build.directory}/${project.artifactId}/lib" username="root" group="root" addParents="false" />
                                    <rpmfileset prefix="/data/toolbox/java21/jmods" filemode='555' dirmode="755" dir="${project.build.directory}/${project.artifactId}/jmods" username="root" group="root" addParents="false" />

                                    <rpmfileset prefix="/data/toolbox/java21/conf" filemode='444' dirmode="755" dir="${project.build.directory}/${project.artifactId}/conf" username="root" group="root" addParents="false" />
                                    <rpmfileset prefix="/data/toolbox/java21/include" filemode='444' dirmode="755" dir="${project.build.directory}/${project.artifactId}/include" username="root" group="root" addParents="false" />
                                    <rpmfileset prefix="/data/toolbox/java21/man/man1" filemode='444' dirmode="755" dir="${project.build.directory}/${project.artifactId}/man/man1" username="root" group="root" addParents="false" />

                                    <rpmfileset prefix="/data/toolbox/java21/" filemode='555' dirmode="755" file="${project.basedir}/src/main/dist/java.sh" username="root" group="root" addParents="false" />

                                    <link path="/data/toolbox/xbin/java21" target="/data/toolbox/java21/java.sh" />
                                </xrpm>
                                <copy file="${project.build.directory}/toolbox-${project.artifactId}-${project.version}-${buildNumber}~${timestamp}.x86_64.rpm" todir="${toolbox.dir}/"/>
                            </target>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

</project>