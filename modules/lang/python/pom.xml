    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-antrun-plugin</artifactId>
                <version>1.8</version>
                <inherited>false</inherited>
                <dependencies>
                    <dependency>
                        <groupId>org.redline-rpm</groupId>
                        <artifactId>redline</artifactId>
                        <version>1.2.9</version>
                        <classifier>jar-with-dependencies</classifier>
                    </dependency>
                    <dependency>
                        <groupId>org.apache.ant</groupId>
                        <artifactId>ant-compress</artifactId>
                        <version>1.5</version>
                    </dependency>
                    <dependency>
                        <groupId>com.github.terefang</groupId>
                        <artifactId>ant-archive-plus</artifactId>
                        <version>1.5.2</version>
                    </dependency>
                    <dependency>
                        <groupId>ant-contrib</groupId>
                        <artifactId>ant-contrib</artifactId>
                        <version>1.0b3</version>
                    </dependency>
                    <!-- https://mvnrepository.com/artifact/org.apache.ant/ant-apache-bsf -->
                    <dependency>
                        <groupId>org.apache.ant</groupId>
                        <artifactId>ant-apache-bsf</artifactId>
                        <version>1.10.12</version>
                    </dependency>

                    <!-- https://mvnrepository.com/artifact/org.beanshell/bsh -->
                    <dependency>
                        <groupId>org.beanshell</groupId>
                        <artifactId>bsh</artifactId>
                        <version>2.0b5</version>
                    </dependency>
                    <!-- https://mvnrepository.com/artifact/commons-logging/commons-logging -->
                    <dependency>
                        <groupId>commons-logging</groupId>
                        <artifactId>commons-logging</artifactId>
                        <version>1.2</version>
                    </dependency>
                </dependencies>
                <executions>
                    <execution>
                        <id>ant</id>
                        <phase>package</phase>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <configuration>
                            <target xmlns:if="ant:if" xmlns:unless="ant:unless">
                                <taskdef classname="org.redline_rpm.ant.RedlineTask" name="xrpm" />
                                <taskdef classname="org.apache.ant.compress.taskdefs.Cpio" name="cpio" />
                                <taskdef resource="net/sf/antcontrib/antlib.xml"/>

                                <mkdir dir="${root.dir}"/>
                                <mkdir dir="${toolchain.dir}"/>
                                <mkdir dir="${project.basedir}/src/main/dist"/>
                                <mkdir dir="${project.build.directory}/${project.artifactId}/${prg.tag}"/>
                                <mkdir dir="${resources.target}"/>

                                <condition property="archive.exists">
                                    <resourceexists>
                                        <file file="${project.basedir}/src/main/dist/${prg.archive}"/>
                                    </resourceexists>
                                </condition>

                                <get unless:true="${archive.exists}" src="${prg.url}" dest="${project.basedir}/src/main/dist/${prg.archive}"/>

                                <exec dir="${project.build.directory}/${project.artifactId}/${prg.tag}" executable="tar">
                                    <arg line="-xvf ${project.basedir}/src/main/dist/${prg.archive} --strip 1" />
                                </exec>

                                <exec dir="${project.build.directory}/${project.artifactId}/${prg.tag}/bin" executable="pip3"  resolveexecutable="true">
                                    <env key="PATH" value="${project.build.directory}/${project.artifactId}/${prg.tag}/bin:${env.PATH}" />
                                    <arg line="install uv" />
                                </exec>
                                <for list="${pkg.list}" delimiter="&#10;" trim="true" param="pkg">
                                    <sequential>
                                        <echo>### installing @{pkg} ...</echo>
                                        <exec dir="${project.build.directory}/${project.artifactId}/${prg.tag}/bin" executable="uv"  resolveexecutable="true">
                                            <env key="PATH" value="${project.build.directory}/${project.artifactId}/${prg.tag}/bin:${env.PATH}" />
                                            <arg line="pip install --system @{pkg}" />
                                        </exec>
                                    </sequential>
                                </for>

                                <replaceregexp match="^#!.*/python-\d\.\d+.*" replace="#!/usr/bin/env python${version.python.short}" byline="true">
                                    <fileset dir="${project.build.directory}/${project.artifactId}/${prg.tag}/bin" includes="*" />
                                </replaceregexp>

                                <echo>### deleting .pyc ... </echo>
                                <delete>
                                    <fileset dir="${project.build.directory}/${project.artifactId}/${prg.tag}" includes="**/*.pyc"/>
                                </delete>

                                <echo>### creating archive ... </echo>
                                <exec dir="${project.build.directory}/${project.artifactId}/${prg.tag}" executable="chmod">
                                    <arg line="-R +x bin/" />
                                </exec>
                                <exec dir="${project.build.directory}/${project.artifactId}/${prg.tag}" executable="tar">
                                    <arg line="--zstd -cf ${project.basedir}/target/toolbox-${prg.tag}.tar.zst bin lib share include" />
                                </exec>
                                <echo>### copying archive ... </echo>
                                <copy file="${project.basedir}/target/toolbox-${prg.tag}.tar.zst" todir="${user.home}/bin/python"/>

                                <echo>### creating rpm ... </echo>
                                <xrpm   architecture="X86_64"
                                        destination="${project.build.directory}"
                                        license="BSD"
                                        group="toolbox"
                                        name="toolbox-${project.artifactId}"
                                        summary="${project.artifactId}."
                                        distribution="nos"
                                        packager="toolbox"
                                        url="none"
                                        vendor="nos"
                                        epoch="${buildNumber}"
                                        release="${buildNumber}~${timestamp}"
                                        version="${project.version}">

                                    <rpmfileset prefix="/data/toolbox/python/bin" filemode='555' dir="${project.build.directory}/${project.artifactId}/${prg.tag}/bin" username="root" group="root" addParents="false" />
                                    <rpmfileset prefix="/data/toolbox/python/lib" filemode='555' dir="${project.build.directory}/${project.artifactId}/${prg.tag}/lib" username="root" group="root" addParents="false" />
                                    <rpmfileset prefix="/data/toolbox/python/share" filemode='444' dir="${project.build.directory}/${project.artifactId}/${prg.tag}/share" username="root" group="root" addParents="false" />
                                    <rpmfileset prefix="/data/toolbox/python/include" filemode='444' dir="${project.build.directory}/${project.artifactId}/${prg.tag}/include" username="root" group="root" addParents="false" />
                                </xrpm>
                                <echo>### copying rpm ... </echo>
                                <copy file="${project.build.directory}/toolbox-${project.artifactId}-${project.version}-${buildNumber}~${timestamp}.x86_64.rpm" todir="${toolbox.dir}/"/>
                            </target>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

