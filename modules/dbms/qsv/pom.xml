<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <parent>
        <artifactId>parent</artifactId>
        <groupId>terefang.makeroot</groupId>
        <version>2021.1.0</version>
        <relativePath>../../../pom.xml</relativePath>
    </parent>
    <modelVersion>4.0.0</modelVersion>

    <groupId>terefang.makeroot.baseos</groupId>
    <artifactId>qsv</artifactId>
    <version>${version.qsv}</version>
    <packaging>pom</packaging>

    <properties>
        <prg.tag>${project.artifactId}-${project.version}</prg.tag>
        <prg.archive>${prg.tag}.zip</prg.archive>
        <prg.url>https://github.com/jqnatividad/qsv/releases/download/${project.version}/qsv-${project.version}-x86_64-unknown-linux</prg.url>
    </properties>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-antrun-plugin</artifactId>
                <version>1.8</version>
                <inherited>false</inherited>
                <dependencies>
                    <dependency>
                        <groupId>org.redline-rpm</groupId>
                        <artifactId>redline</artifactId>
                        <version>1.2.9</version>
                        <classifier>jar-with-dependencies</classifier>
                    </dependency>
                    <dependency>
                        <groupId>org.apache.ant</groupId>
                        <artifactId>ant-compress</artifactId>
                        <version>1.5</version>
                    </dependency>
                    <dependency>
                        <groupId>com.github.terefang</groupId>
                        <artifactId>ant-archive-plus</artifactId>
                        <version>1.5.2</version>
                    </dependency>
                </dependencies>
                <executions>
                    <execution>
                        <id>ant</id>
                        <phase>package</phase>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <configuration>
                            <target xmlns:if="ant:if" xmlns:unless="ant:unless">
                                <taskdef classname="org.redline_rpm.ant.RedlineTask" name="xrpm" />
                                <taskdef classname="org.apache.ant.compress.taskdefs.Cpio" name="cpio" />

                                <taskdef name="xtar" classname="com.github.terefang.ant.archiveplus.taskdefs.Tar" />
                                <typedef name="symlink" classname="com.github.terefang.ant.archiveplus.resources.SymbolicLink" />

                                <mkdir dir="${rpm.path}"/>
                                <mkdir dir="${project.build.directory}/${project.artifactId}"/>
                                <mkdir dir="${project.basedir}/src/main/dist"/>

                                <mkdir dir="${root.dir}/usr/bin/"/>
                                <mkdir dir="${root.dir}/usr/man/man1"/>

                                <get src="${prg.url}-musl.zip" dest="${project.build.directory}/${prg.archive}" />

                                <exec dir="${project.build.directory}/${project.artifactId}/" executable="unzip">
                                    <arg line="-o -j ${project.build.directory}/${prg.archive}" />
                                </exec>

                                <copy file="${project.build.directory}/${project.artifactId}/qsv"     tofile="${root.dir}/usr/bin/qsv-musl" />
                                <copy file="${project.build.directory}/${project.artifactId}/qsvdp"   tofile="${root.dir}/usr/bin/qsvdp-musl" />
                                <copy file="${project.build.directory}/${project.artifactId}/qsvpdp"  tofile="${root.dir}/usr/bin/qsvpdp-musl" />
                                <copy file="${project.build.directory}/${project.artifactId}/qsvlite" tofile="${root.dir}/usr/bin/qsvlite-musl" />

                                <get src="${prg.url}-gnu.zip" dest="${project.build.directory}/${prg.archive}" />

                                <exec dir="${project.build.directory}/${project.artifactId}/" executable="unzip">
                                    <arg line="-o -j ${project.build.directory}/${prg.archive}" />
                                </exec>

                                <copy file="${project.build.directory}/${project.artifactId}/qsv"     tofile="${root.dir}/usr/bin/qsv-gnu" />
                                <copy file="${project.build.directory}/${project.artifactId}/qsvdp"   tofile="${root.dir}/usr/bin/qsvdp-gnu" />
                                <copy file="${project.build.directory}/${project.artifactId}/qsvpdp"  tofile="${root.dir}/usr/bin/qsvpdp-gnu" />
                                <copy file="${project.build.directory}/${project.artifactId}/qsvlite" tofile="${root.dir}/usr/bin/qsvlite-gnu" />

                                <xrpm
                                        architecture="X86_64"
                                        destination="${project.build.directory}"
                                        license="GNU"
                                        group="${project.artifactId}"
                                        name="toolbox-${project.artifactId}"
                                        summary="${project.artifactId}"
                                        distribution="${project.artifactId}"
                                        packager="${project.artifactId}"
                                        url=""
                                        vendor="${project.artifactId}"
                                        epoch="${buildNumber}"
                                        release="${buildNumber}~${timestamp}"
                                        version="${project.version}">

                                    <rpmfileset prefix="/data/toolbox/xbin" filemode='555' dir="${root.dir}/usr/bin/" username="root" group="root" addParents="false" />

                                    <link path="/data/toolbox/xbin/qsv" target="/data/toolbox/xbin/qsv-musl" />
                                    <link path="/data/toolbox/xbin/qsvdp" target="/data/toolbox/xbin/qsvdp-musl" />
                                    <link path="/data/toolbox/xbin/qsvpdp" target="/data/toolbox/xbin/qsvpdp-musl" />
                                    <link path="/data/toolbox/xbin/qsvlite" target="/data/toolbox/xbin/qsvlite-musl" />
                                </xrpm>

                                <copy file="${project.build.directory}/toolbox-${project.artifactId}-${project.version}-${buildNumber}~${timestamp}.x86_64.rpm" todir="${toolbox.dir}/"/>
                            </target>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

</project>