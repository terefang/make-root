<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <parent>
        <artifactId>parent</artifactId>
        <groupId>terefang.makeroot</groupId>
        <version>2021.1.0</version>
        <relativePath>../../../pom.xml</relativePath>
    </parent>
    <modelVersion>4.0.0</modelVersion>

    <groupId>terefang.makeroot.muslsys</groupId>
    <artifactId>duckdb</artifactId>
    <version>${version.duckdb}</version>
    <packaging>pom</packaging>

    <properties>
        <prg.archive>${project.artifactId}-${project.version}.tar.gz</prg.archive>
        <prg.tag>${project.artifactId}-${project.version}</prg.tag>
        <prg.url>https://github.com/duckdb/duckdb/archive/refs/tags/v${project.version}.tar.gz</prg.url>
        <prg.bin>https://github.com/duckdb/duckdb/releases/download/v${project.version}/duckdb_cli-linux-amd64.zip</prg.bin>
        <duckdb.community.list>
            datasketches
            marisa
            airport
            tsid
            quickjs
            pdal
            minijinja
            markdown
            hashfuncs
            h3
            crypto
            lindel
            webdavfs
            sshfs
            shellfs
            hostfs
            yaml
            zipfs
            lua
            tsid
            gsheets
            wireduck
            netquack
        </duckdb.community.list>
        <duckdb.core.list>
            autocomplete
            avro
            ducklake
            encodings
            fts
            iceberg
            parquet
            json
            inet
            excel
            httpfs
            mysql
            postgres
            sqlite
            spatial
            ui
        </duckdb.core.list>
    </properties>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-antrun-plugin</artifactId>
                <version>1.8</version>
                <inherited>false</inherited>
                <dependencies>
                    <dependency>
                        <groupId>org.redline-rpm</groupId>
                        <artifactId>redline</artifactId>
                        <version>1.2.9</version>
                        <classifier>jar-with-dependencies</classifier>
                    </dependency>
                    <dependency>
                        <groupId>org.apache.ant</groupId>
                        <artifactId>ant-compress</artifactId>
                        <version>1.5</version>
                    </dependency>
                    <dependency>
                        <groupId>com.github.terefang</groupId>
                        <artifactId>ant-archive-plus</artifactId>
                        <version>1.5.2</version>
                    </dependency>
                    <dependency>
                        <groupId>ant-contrib</groupId>
                        <artifactId>ant-contrib</artifactId>
                        <version>1.0b3</version>
                    </dependency>
                    <!-- https://mvnrepository.com/artifact/org.apache.ant/ant-apache-bsf -->
                    <dependency>
                        <groupId>org.apache.ant</groupId>
                        <artifactId>ant-apache-bsf</artifactId>
                        <version>1.10.12</version>
                    </dependency>

                    <!-- https://mvnrepository.com/artifact/org.beanshell/bsh -->
                    <dependency>
                        <groupId>org.beanshell</groupId>
                        <artifactId>bsh</artifactId>
                        <version>2.0b5</version>
                    </dependency>
                    <!-- https://mvnrepository.com/artifact/commons-logging/commons-logging -->
                    <dependency>
                        <groupId>commons-logging</groupId>
                        <artifactId>commons-logging</artifactId>
                        <version>1.2</version>
                    </dependency>
                </dependencies>
                <executions>
                    <execution>
                        <id>ant</id>
                        <phase>package</phase>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <configuration>
                            <target xmlns:if="ant:if" xmlns:unless="ant:unless">
                                <taskdef classname="org.redline_rpm.ant.RedlineTask" name="xrpm" />
                                <taskdef classname="org.apache.ant.compress.taskdefs.Cpio" name="cpio" />
                                <taskdef resource="net/sf/antcontrib/antlib.xml"/>

                                <mkdir dir="${root.dir}/usr/bin"/>
                                <mkdir dir="${toolchain.dir}"/>
                                <mkdir dir="${project.basedir}/src/main/dist"/>
                                <mkdir dir="${resources.target}"/>
                                <mkdir dir="${project.build.directory}/${project.artifactId}/${prg.tag}"/>

                                <get src="${prg.bin}" dest="${project.basedir}/src/main/dist/${prg.tag}.zip"/>

                                <exec unless:true="${final.exists}" dir="${project.build.directory}/${project.artifactId}/${prg.tag}" executable="unzip">
                                    <arg line="-j ${project.basedir}/src/main/dist/${prg.tag}.zip" />
                                </exec>

                                <copy tofile="${root.dir}/usr/bin/duckdb" file="${project.build.directory}/${project.artifactId}/${prg.tag}/duckdb" />

                                <exec unless:true="${final.exists}" dir="${root.dir}" executable="chmod">
                                    <arg line="+x usr/bin/duckdb" />
                                </exec>

                                <mkdir dir="${root.dir}/usr/lib/duckdb"/>

                                <echo file="${root.dir}/usr/lib/duckdb/duckdb.rc" append="true">
                                    set extension_directory='/data/toolbox/duckdb' ;${line.separator}
                                </echo>

                                <for list="${duckdb.core.list}" delimiter="&#10;" trim="true" param="ext">
                                    <sequential>
                                        <echo>installing @{ext}</echo>
                                        <exec unless:true="${final.exists}" dir="${root.dir}" executable="${root.dir}/usr/bin/duckdb">
                                            <arg line="-unsigned -c " />
                                            <arg value="set extension_directory='${root.dir}/usr/lib/duckdb'; install @{ext};" />
                                        </exec>
                                        <echo file="${root.dir}/usr/lib/duckdb/duckdb.rc" append="true">
                                            -- LOAD @{ext} ;${line.separator}
                                        </echo>
                                    </sequential>
                                </for>

                                <for list="${duckdb.community.list}" delimiter="&#10;" trim="true" param="ext">
                                    <sequential>
                                        <echo>installing @{ext}</echo>
                                        <exec unless:true="${final.exists}" dir="${root.dir}" executable="${root.dir}/usr/bin/duckdb">
                                            <arg line="-unsigned -c " />
                                            <arg value="set extension_directory='${root.dir}/usr/lib/duckdb'; install @{ext} FROM community;" />
                                        </exec>
                                        <echo file="${root.dir}/usr/lib/duckdb/duckdb.rc" append="true">
                                            -- LOAD @{ext} ;${line.separator}
                                        </echo>
                                    </sequential>
                                </for>

                                <exec unless:true="${final.exists}" dir="${root.dir}/usr" executable="tar">
                                    <arg line="-cvf ${resources.target}/muslsys-${prg.tag}.tgz ." />
                                </exec>

                                <echo file="${root.dir}/usr/bin/duckdb_wrapper">#!/bin/sh
/data/toolbox/xbin/duckdb -init /data/toolbox/duckdb/duckdb.rc "$@"
                                </echo>

                                <xrpm
                                        architecture="X86_64"
                                        destination="${project.build.directory}"
                                        license="ASL"
                                        group="${project.artifactId}"
                                        name="toolbox-${project.artifactId}"
                                        summary="${project.artifactId}"
                                        distribution="${project.artifactId}"
                                        packager="${project.artifactId}"
                                        url=""
                                        vendor="${project.artifactId}"
                                        epoch="${buildNumber}"
                                        release="${buildNumber}~${timestamp}"
                                        version="${project.version}">

                                    <rpmfileset prefix="/data/toolbox/xbin" filemode='555' dir="${root.dir}/usr/bin" username="root" group="root" addParents="false" />
                                    <rpmfileset prefix="/data/toolbox/duckdb" filemode='555' dir="${root.dir}/usr/lib/duckdb" username="root" group="root" addParents="false" />

                                </xrpm>

                                <copy file="${project.build.directory}/toolbox-${project.artifactId}-${project.version}-${buildNumber}~${timestamp}.x86_64.rpm" todir="${toolbox.dir}/"/>
                            </target>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

</project>